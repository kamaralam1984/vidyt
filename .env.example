# ==============================================================================
# VidYT — Environment Variables Template
# Copy this file to `.env.local` (dev) or `.env` (prod) and fill in values.
# Never commit actual secrets to git.
# ==============================================================================

# ---- Core ----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# ---- Google Search Console (powers /admin/super/seo-pages analytics) ----
# Service account JSON (base64-encoded preferred, raw JSON also accepted).
# Create at https://console.cloud.google.com/iam-admin/serviceaccounts —
# grant the service-account email read access to the Search Console property
# at https://search.google.com/search-console/users. Without this the UI
# gracefully shows "GSC not configured" instead of erroring.
GSC_SERVICE_ACCOUNT_JSON=
GSC_SITE_URL=sc-domain:vidyt.com

# ---- MongoDB ----
MONGODB_URI=mongodb://localhost:27017/vidyt
MONGODB_DB=vidyt

# ---- Redis (rate limiting / queues / cache) ----
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ---- JWT / Auth ----
JWT_SECRET=replace-me-with-openssl-rand-base64-64
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-me-with-a-different-secret
REFRESH_TOKEN_EXPIRES_IN=30d

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com

# ---- YouTube Data API ----
YOUTUBE_API_KEY=
YOUTUBE_API_KEY_POOL=key1,key2,key3

# ---- OpenAI / AI ----
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=
AI_MODEL_DEFAULT=gpt-4o-mini

# ---- Razorpay (payments) ----
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx

# ---- Email (Resend / SMTP) ----
RESEND_API_KEY=re_xxx
EMAIL_FROM=VidYT <noreply@vidyt.com>
EMAIL_SUPPORT=support@vidyt.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ---- Analytics / SEO ----
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_ADSENSE_ID=
GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---- Error Tracking ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ---- Cloudflare ----
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# ---- CAPTCHA (Cloudflare Turnstile) ----
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- 2FA (TOTP) ----
TOTP_ISSUER=VidYT
TOTP_ENCRYPTION_KEY=replace-with-32-byte-hex

# ---- Admin Seed ----
SUPER_ADMIN_EMAIL=admin@vidyt.com
SUPER_ADMIN_PASSWORD=change-me-strong-password

# ---- Feature Flags ----
FEATURE_2FA_ENABLED=true
FEATURE_CAPTCHA_ENABLED=true
FEATURE_I18N_ENABLED=false

# ---- Storage (uploads) ----
UPLOAD_DIR=./public/uploads
MAX_UPLOAD_MB=50

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
