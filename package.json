    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^11.0.0",
    "google-trends-api": "^4.9.2",
    "googleapis": "^171.4.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.1",
