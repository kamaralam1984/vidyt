{
  "name": "vidyt",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=--max_old_space_size=4096 next dev",
    "dev:ws": "ts-node --project tsconfig.server.json server.ts",
    "dev:worker": "ts-node --project tsconfig.server.json workers/aiWorker.ts",
    "dev:tracking:worker": "ts-node --project tsconfig.server.json workers/trackingWorker.ts",
    "build": "NODE_OPTIONS=--max_old_space_size=8192 next build",
    "start": "next start",
    "start:ws": "NODE_ENV=production ts-node --project tsconfig.server.json server.ts",
    "start:worker": "NODE_ENV=production ts-node --project tsconfig.server.json workers/aiWorker.ts",
    "start:tracking:worker": "NODE_ENV=production ts-node --project tsconfig.server.json workers/trackingWorker.ts",
    "dev:email:worker": "ts-node --project tsconfig.server.json workers/bulkEmailWorker.ts",
    "start:email:worker": "NODE_ENV=production ts-node --project tsconfig.server.json workers/bulkEmailWorker.ts",
    "lint": "next lint",
    "test": "node --test tests/ai-systems.test.js tests/unit/*.unit.test.cjs",
    "test:unit": "npm run test",
    "test:integration": "node --test tests/integration/*.test.cjs",
    "test:worker": "node --test tests/worker/aiJobLog.test.cjs && node --test tests/worker/trackingWorker.test.cjs",
    "test:cron": "node --test tests/cron/*.test.cjs",
    "test:ts": "echo \"No TS unit tests configured\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:integration && npm run test:worker && npm run test:cron",
    "typecheck": "tsc --noEmit",
    "analyze": "ANALYZE=true npm run build",
    "prepare": "husky install || true",
    "mobile:install": "cd mobile && npm install",
    "mobile:sync": "cd mobile && npx cap sync",
    "mobile:android": "cd mobile && npm run open:android",
    "mobile:run:android": "cd mobile && npm run run:android"
  },
  "dependencies": {
    "@capacitor/cli": "^6.1.0",
    "@capacitor/core": "^6.1.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@react-oauth/google": "^0.13.4",
    "@sentry/nextjs": "^10.45.0",
    "@tensorflow/tfjs": "^4.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.11",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.1",
    "compromise": "^14.12.0",
    "date-fns": "^3.3.0",
    "express": "^5.2.1",
    "face-api.js": "^0.22.2",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^11.0.0",
    "google-auth-library": "^10.6.2",
    "google-trends-api": "^4.9.2",
    "googleapis": "^171.4.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.0",
    "lighthouse": "^12.8.2",
    "lucide-react": "^0.344.0",
    "mongodb": "^6.3.0",
    "mongoose": "^8.0.0",
    "natural": "^6.10.0",
    "next": "^14.2.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.2",
    "openai": "^4.104.0",
    "otpauth": "^9.3.2",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0",
    "resend": "^4.8.0",
    "server-only": "^0.0.1",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "ytdl-core": "npm:@distube/ytdl-core@^4.16.12",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "env-cmd": "^10.1.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
