    "jspdf": "^4.2.0",
    "lucide-react": "^0.344.0",
    "mongodb": "^6.3.0",
    "mongoose": "^8.0.0",
    "natural": "^6.10.0",
    "next": "^14.2.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.2",
    "openai": "^4.104.0",
