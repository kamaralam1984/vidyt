{
  "name": "viralboost-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:ws": "ts-node --project tsconfig.server.json server.ts",
    "dev:worker": "ts-node --project tsconfig.server.json workers/aiWorker.ts",
    "build": "NODE_OPTIONS=--max_old_space_size=8192 next build",
    "start": "next start",
    "start:ws": "NODE_ENV=production ts-node --project tsconfig.server.json server.ts",
    "start:worker": "NODE_ENV=production ts-node --project tsconfig.server.json workers/aiWorker.ts",
    "lint": "next lint",
    "test": "node --test tests/**/*.test.js",
    "mobile:install": "cd mobile && npm install",
    "mobile:sync": "cd mobile && npx cap sync",
    "mobile:android": "cd mobile && npm run open:android",
    "mobile:run:android": "cd mobile && npm run run:android"
  },
  "dependencies": {
