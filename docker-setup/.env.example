# ============================================
# ViralBoost AI - Docker Environment Configuration
# Copy this file to .env and update with your values
# ============================================

# ============================================
# Environment Mode
# ============================================
NODE_ENV=production
ENVIRONMENT=production
LOG_LEVEL=info

# ============================================
# MongoDB Configuration
# ============================================
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=change-this-password-in-production
MONGO_DATABASE=viralboost
MONGO_INITDB_DATABASE=viralboost
# Full URI (auto-generated in docker-compose): mongodb://user:pass@mongodb:27017/db?authSource=admin

# ============================================
# Redis Configuration
# ============================================
REDIS_PASSWORD=change-this-password-in-production
REDIS_MAX_MEMORY=512mb
# Full URI (auto-generated): redis://:password@redis:6379

# ============================================
# JWT & Authentication
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-chars
JWT_EXPIRES_IN=7d
OTP_EXPIRY=300

# ============================================
# YouTube OAuth Configuration
# Get from: https://console.cloud.google.com/
# ============================================
YOUTUBE_CLIENT_ID=your-youtube-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_CALLBACK_URL=https://yourdomain.com/api/youtube/callback

# ============================================
# Stripe Payment Configuration
# Get from: https://dashboard.stripe.com/
# ============================================
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# ============================================
# SendGrid Email Configuration
# Get from: https://sendgrid.com/
# ============================================
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# Frontend Configuration
# ============================================
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
NEXT_PUBLIC_BACKEND_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ============================================
# Service URLs (Internal Docker Network)
# These are auto-configured but can be overridden
# ============================================
BACKEND_URL=http://backend:5000
AI_SERVICE_URL=http://ai-service:5001
WORKER_SERVICE_URL=http://worker:5002

# ============================================
# Worker Configuration
# ============================================
WORKER_CONCURRENCY=4
WORKER_NAME=worker-1

# ============================================
# Feature Flags
# ============================================
ENABLE_AI_PREDICTIONS=true
ENABLE_QUEUE_PROCESSING=true
ENABLE_WEBHOOK_EVENTS=true
ENABLE_ANALYTICS_EXPORT=true

# ============================================
# Security Configuration
# ============================================
CORS_ORIGIN=https://yourdomain.com
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ============================================
# API Rate Limiting
# ============================================
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Database Backup (Optional)
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Every day at 2 AM

# ============================================
# Monitoring & Logging
# ============================================
SENTRY_DSN=
DATADOG_API_KEY=
SLACK_WEBHOOK_URL=

# ============================================
# AWS Configuration (For S3 uploads - optional)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ============================================
# Additional Configuration
# ============================================
MAX_FILE_SIZE=524288000  # 500MB in bytes
VIDEO_PROCESSING_TIMEOUT=3600  # 1 hour
SESSION_TIMEOUT=86400  # 24 hours in seconds
